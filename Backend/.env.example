# ──────────────────────────────────────────────────────────────────────────
# VoxPilot — Environment Configuration
# Copy to .env and adjust as needed.
# ──────────────────────────────────────────────────────────────────────────

# TTS engine: "speecht5" | "system" | "fallback" | "fake"
VOXPILOT_ENGINE=speecht5

# Maximum input text length (characters)
VOXPILOT_MAX_TEXT_LENGTH=1000

# Directory for generated audio files
VOXPILOT_AUDIO_DIR=data/generated

# SQLite database path
VOXPILOT_DB_PATH=data/voxpilot.db

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
VOXPILOT_LOG_LEVEL=INFO

# API server bind address and port
VOXPILOT_HOST=0.0.0.0
VOXPILOT_PORT=8000

# Application version string
VOXPILOT_APP_VERSION=0.1.0
